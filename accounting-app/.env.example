# Anthropic API (Claude Vision für Belegerkennung)
ANTHROPIC_API_KEY=

# Google OAuth2 (für Gmail + Google Sheets)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_SHEETS_ID=

# Kontist OAuth2 (Banking API)
KONTIST_CLIENT_ID=
KONTIST_CLIENT_SECRET=
KONTIST_REDIRECT_URI=http://localhost:3000/auth/kontist/callback

# Server
PORT=3000
NODE_ENV=development
